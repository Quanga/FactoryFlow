# ──────────────────────────────────────────────────────────────────────────────
# AECE Checkpoint — Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the PostgreSQL database created by Docker.
# Change this to something strong before running in production.
DB_PASSWORD=changeme_use_a_strong_password

# ── App ───────────────────────────────────────────────────────────────────────
# Port the app listens on (host-side). Access the app at http://localhost:PORT
PORT=5000

# Public-facing URL of the app — used in password reset email links.
# If running locally: http://localhost:5000
# If running behind a domain: https://aece.yourdomain.com
APP_URL=http://localhost:5000

# ── Email (optional — for password reset emails) ──────────────────────────────
# Get this from your Postmark account: https://postmarkapp.com
# Leave blank to disable email features.
POSTMARK_SERVER_TOKEN=
